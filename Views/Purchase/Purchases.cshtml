@{
    ViewData["Title"] = "Purchase Management";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Datatables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">

    <!-- Select2 -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <style>
        body {
            background: #f4f6f9;
        }

        .card {
            border-radius: 14px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            border: none;
        }

        .card-header {
            background: linear-gradient(90deg,#0d6efd,#0a58ca);
            color: white;
            border-radius: 14px 14px 0 0;
        }

        .input-group-text {
            width: 45px;
            justify-content: center;
        }

        .btn-success, .btn-warning {
            border-radius: 10px;
            padding: 10px 25px;
        }

        table.dataTable thead th {
            background-color: #212529 !important;
            color: #fff !important;
        }

        #tblProductList th, #tblProductList td, #tblPurchases th, #tblPurchases td {
            text-align: center;
            vertical-align: middle;
        }



    </style>
    
       
</head>
<body class="p-0">

    <div class="container">
        <div class="card main-card d-flex justify-content-center align-items-center" style="height:10vh; padding:1rem;">
            <div class="row w-100 g-3">

                <div class="col-md-6 d-flex">
                    <a href="/Purchase/purchases" class="btn btn-primary btn-lg w-100 d-flex justify-content-center align-items-center">
                        <i class="bi bi-cart-plus me-2"></i> Purchase Entry
                    </a>
                </div>

                <div class="col-md-6 d-flex">
                    <a href="/PurchaseReturn/index" class="btn btn-success btn-lg w-100 d-flex justify-content-center align-items-center">
                        <i class="bi bi-arrow-counterclockwise me-2"></i> Purchase Return
                    </a>
                </div>

            </div>
        </div>
    </div>
    <!-- HEADER -->
    <div class="card mt-3">
        <div class="card-header"><h5 class="mb-0"><i class="bi bi-cart-check-fill me-2"></i>Purchase Header</h5></div>
        <div class="card-body">
            <input type="hidden" id="PurchaseId">
            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label ">Purchase Date</label>
                    <div class="input-group">
                        <span class="input-group-text bg-primary text-white"><i class="bi bi-calendar-date-fill"></i></span>
                        <input type="date" id="PurchaseDate" class="form-control">
                    </div>
                </div>
                <div class="col-md-8">
                    <label class="form-label bi bi-person-fill">Supplier</label>
                    <div class="input-group">
                        <select id="SupplierId" class="form-select"><option value="">-- Select Supplier --</option></select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- DETAILS -->
    <div class="card mt-4">
        <div class="card-header"><h5 class="mb-0"><i class="bi bi-bag-check-fill me-2"></i>Purchase Details</h5></div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label bi bi-box-seam-fill">Product</label>
                    <div class="input-group">
                        <select id="ProductId" class="form-select"><option value="">-- Select Product --</option></select>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Qty</label>
                    <div class="input-group">
                        <span class="input-group-text bg-warning text-dark"><i class="bi bi-123"></i></span>
                        <input type="text" id="Qty" class="form-control">
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Cost Price</label>
                    <div class="input-group">
                        <span class="input-group-text bg-secondary text-white"><i class="bi bi-currency-dollar"></i></span>
                        <input type="text" id="CostPrice" class="form-control">
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Amount</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark text-white"><i class="bi bi-calculator-fill"></i></span>
                        <input type="text" id="Amount" class="form-control" readonly>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Barcode</label>
                    <div class="input-group">
                        <span class="input-group-text bg-danger text-white"><i class="bi bi-upc-scan"></i></span>
                        <input type="text" id="Barcode" class="form-control">
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <button type="button" id="btnAddToList" class="btn btn-primary me-2"><i class="bi bi-cart-plus-fill me-1"></i>Add To List</button>
                <button type="button" id="btnClearProduct" class="btn btn-secondary"><i class="bi bi-x-lg me-1"></i>Clear</button>
            </div>

            <table class="table table-bordered mt-3" id="tblProductList">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Cost Price</th>
                        <th>Amount</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr>
                        <th colspan="3">Total</th>
                        <th id="totalAmount">0</th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>

            <div class="text-end mb-3">
                <button id="btnSubmitPurchase" class="btn btn-success btn-lg"><i class="bi bi-cart-check-fill me-2"></i>Purchase</button>
                <button class="btn btn-info text-white btn-lg" onclick="openReportPage()"><i class="bi bi-file-earmark-text-fill me-2"></i>Report</button>
            </div>

            <table id="tblPurchases" class="table table-bordered table-striped mt-4">
                <thead>
                    <tr>
                        <th>Purchase ID</th>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Cost</th>
                        <th>Amount</th>
                        <th>Total</th>
                        <th>Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>

    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        let table;
        let productList = [];

        // Load suppliers
        function LoadSuppliers(){
            $.get("/Purchase/GetSuppliers", function(res){
                $("#SupplierId").html('<option></option>');
                $.each(res, function(i,v){
                    $("#SupplierId").append(`<option value="${v.supplierId}">${v.supplierName}</option>`);
                });
                if($('#SupplierId').hasClass("select2-hidden-accessible")) $('#SupplierId').select2('destroy');
                $('#SupplierId').select2({ width:'100%', placeholder:'Select Supplier', allowClear:true });
            });
        }

        // Load products
        function LoadProducts(){
            $.get("/Purchase/GetProducts", function(res){
                $("#ProductId").html('<option></option>');
                $.each(res,function(i,v){
                    $("#ProductId").append(`<option value="${v.productId}">${v.productName}</option>`);
                });
                if($('#ProductId').hasClass("select2-hidden-accessible")) $('#ProductId').select2('destroy');
                $('#ProductId').select2({ width:'100%', placeholder:'Select Product', allowClear:true });
            });
        }

        // Add to product list
        $("#btnAddToList").click(function(){
            let productId = $("#ProductId").val();
            let productName = $("#ProductId option:selected").text();
            let qty = parseFloat($("#Qty").val()) || 0;
            let cost = parseFloat($("#CostPrice").val()) || 0;
            let amount = qty * cost;
            if(!productId || qty<=0 || cost<=0){ Swal.fire("Warning","Select product & valid Qty/Cost","warning"); return; }
            productList.push({ productId, productName, qty, costPrice:cost, amount, barcode: $("#Barcode").val() });
            renderProductList();
            clearProductFields();
        });

        $("#btnClearProduct").click(clearProductFields);
        function clearProductFields(){ $("#ProductId,#Qty,#CostPrice,#Amount,#Barcode").val("").trigger('change'); }

        // Render product list table
        function renderProductList(){
            let tbody = $("#tblProductList tbody"); tbody.empty();
            let total = 0;
            productList.forEach((p,i)=>{
                total += p.amount;
                tbody.append(`<tr>
                    <td>${p.productName}</td>
                    <td>${p.qty}</td>
                    <td>${p.costPrice}</td>
                    <td>${p.amount.toFixed(2)}</td>
                    <td><button class="btn btn-sm btn-danger removeItem" data-index="${i}"><i class="bi bi-trash-fill"></i></button></td>
                </tr>`);
            });
            $("#totalAmount").text(total.toFixed(2));
            $(".removeItem").click(function(){
                productList.splice($(this).data("index"),1);
                renderProductList();
            });
        }

        // Add purchase
               function AddPurchase() {
            if (productList.length === 0) {
                Swal.fire("Warning", "Add at least one product", "warning");
                return;
            }

            let vm = {
                purchaseDate: $("#PurchaseDate").val(),
                supplierId: $("#SupplierId").val(),
                details: productList
            };

            if (!vm.purchaseDate || !vm.supplierId) {
                Swal.fire("Warning", "Fill all required fields", "warning");
                return;
            }

            $.ajax({
                url: "/Purchase/AddPurchase",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(vm),
                success: function () {
                    Swal.fire("Success", "Purchase saved", "success");
                    ClearForm();
                    productList = [];
                    renderProductList();
                    table.ajax.reload();
                },
                error: function (xhr) {
                    Swal.fire("Error", xhr.responseText || "Could not save purchase", "error");
                }
            });
        }

               function ClearForm(){
            $("#PurchaseId").val("");
            $("#PurchaseDate").val("");

            // ✅ Supplier properly clear with Select2
            $("#SupplierId").val(null).trigger("change");

            clearProductFields();

            $("#btnSubmitPurchase")
                .text("Purchase")
                .removeClass("btn-warning")
                .addClass("btn-success")
                .off("click")
                .on("click", AddPurchase);
        }
        // Edit, Update, Delete Purchase
        function EditPurchase(id){
            $.get("/Purchase/GetPurchaseById",{purchaseId:id}, function(d){
                $("#PurchaseId").val(d.purchaseId);
                $("#PurchaseDate").val(d.purchaseDate.split('T')[0]);
                $("#SupplierId").val(d.supplierId).trigger('change');
                $("#ProductId").val(d.productId).trigger('change');
                $("#Qty").val(d.qty);
                $("#CostPrice").val(d.costPrice);
                $("#Amount").val(d.amount);
                $("#Barcode").val(d.barcode);
                $("#btnSubmitPurchase").text("Update Purchase").removeClass("btn-success").addClass("btn-warning").off("click").on("click", UpdatePurchase);
            });
        }

        function UpdatePurchase(){
            let purchaseId = $("#PurchaseId").val();
            if(!purchaseId){ Swal.fire("Error","PurchaseId missing","error"); return; }
            let vm = {
                purchaseId: purchaseId,
                purchaseDate: $("#PurchaseDate").val(),
                supplierId: $("#SupplierId").val(),
                details:[{
                    productId: $("#ProductId").val(),
                    qty: parseFloat($("#Qty").val())||0,
                    costPrice: parseFloat($("#CostPrice").val())||0,
                    amount: parseFloat($("#Amount").val())||0,
                    barcode: $("#Barcode").val()
                }]
            };
            $.ajax({
                url:"/Purchase/UpdatePurchase",
                type:"POST", contentType:"application/json", data:JSON.stringify(vm),
                success:function(){ Swal.fire("Success","Purchase updated","success"); ClearForm(); table.ajax.reload(); },
                error:function(xhr){ Swal.fire("Error",xhr.responseText||"Update failed","error"); }
            });
        }

        function DeletePurchase(id){
            Swal.fire({ title:"Are you sure?", text:"This purchase will be permanently deleted!", icon:"warning", showCancelButton:true, confirmButtonColor:"#d33", confirmButtonText:"Yes, delete it!" })
            .then((result)=>{
                if(result.isConfirmed){
                    $.post("/Purchase/DeletePurchase",{purchaseId:id}, function(){ Swal.fire("Deleted","Purchase deleted","success"); table.ajax.reload(); });
                }
            });
        }

        // Print Purchase
        function PrintPurchase(id){
            $.get("/Purchase/GetPurchaseById",{purchaseId:id}, function(d){
                let logoUrl = '@Url.Content("/1.jpg")';
                let w = window.open('','','width=900,height=700');
                w.document.write(`
                    <html><head><title>Purchase Invoice</title></head>
                    <body style="font-family:Segoe UI;padding:0;margin:0;">
                    <div style="width:850px;margin:20px auto;padding:30px;background:#fff;border-radius:10px;">
                    <div style="display:flex;justify-content:space-between;border-bottom:3px solid #0d6efd;padding-bottom:15px;">
                        <img src="${logoUrl}" style="height:70px"/>
                        <div style="text-align:right;color:#0d6efd">
                            <h2>EZware Technologies</h2>
                            <div>Enterprise Software & ERP Solutions</div>
                            <div>Abu Dhabi & Dubai – UAE</div>
                        </div>
                    </div>
                    <h2 style="text-align:center;margin:25px 0;color:#333;">PURCHASE INVOICE</h2>
                    <div>Purchase ID: ${d.purchaseId}</div>
                    <div>Supplier: ${d.supplierName}</div>
                    <div>Date: ${d.purchaseDate.split('T')[0]}</div>
                    <table border="1" cellpadding="10" cellspacing="0" style="width:100%;margin-top:20px;border-collapse:collapse;text-align:center;">
                        <thead style="background:#0d6efd;color:white;">
                            <tr><th>Product</th><th>Quantity</th><th>Cost Price</th><th>Amount</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>${d.productName}</td><td>${d.qty}</td><td>${d.costPrice}</td><td>${d.amount}</td></tr>
                        </tbody>
                    </table>
                    <div style="text-align:right;font-weight:bold;margin-top:20px;color:#0d6efd;">Total Amount: ${d.amount}</div>
                    </div></body></html>`);
                w.document.close(); w.print();
            });
        }

        function openReportPage(){ window.location.href="/Purchase/ReportPage"; }

        // Load DataTable
        function LoadTable(){
            table = $("#tblPurchases").DataTable({
                ajax:"/Purchase/GetPurchases",
                columns:[
                    {data:"purchaseId"},
                    {data:"productName"},
                    {data:"qty"},
                    {data:"costPrice"},
                    {data:"amount"},
                    {data:"totalAmount"},
                    {data:"purchaseId",
                     render:function(id){
                        return `<div class="d-flex gap-1 w-100">
                            <button class="btn btn-sm btn-primary" onclick="EditPurchase('${id}')"><i class="bi bi-pencil-fill"></i></button>
                            <button class="btn btn-sm btn-info text-white" onclick="PrintPurchase('${id}')"><i class="bi bi-printer-fill"></i></button>
                            <button class="btn btn-sm btn-danger" onclick="DeletePurchase('${id}')"><i class="bi bi-trash-fill"></i></button>
                        </div>`;
                     }}
                ]
            });
        }

        $(document).ready(function(){
            LoadSuppliers(); LoadProducts(); LoadTable();
            $("#btnSubmitPurchase").click(AddPurchase);
            $("#Qty,#CostPrice").on("keyup change",function(){
                let qty=parseFloat($("#Qty").val())||0;
                let cost=parseFloat($("#CostPrice").val())||0;
                $("#Amount").val((qty*cost).toFixed(2));
            });
        });
    </script>
</body>
</html>