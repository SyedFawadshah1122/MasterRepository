@{
    ViewData["Title"] = "Purchase Reports";
    Layout = "_Layout";
}

<!DOCTYPE html>
<html>
<head>
    <title>Purchase Reports</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">

    <!-- ✅ ChartJS Preload (Fix) -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            font-family: Georgia, serif;
            background: #f9f9f9;
            padding: 20px;
        }

        h2 {
            background: linear-gradient(90deg,#0d6efd,#0a58ca);
            color: white;
            border-radius: 12px;
            padding: 10px;
            height: 50px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: #fff;
        }

        th, td {
            padding: 10px;
            text-align: center;
        }

        th {
            background: #0d6efd;
            color: #fff;
        }

        tbody tr:nth-child(even) {
            background: #f4f6f9;
        }

        tbody tr:hover {
            background: #dbe9ff;
        }

        .graph-container {
            background: #fff;
            padding: 15px;
            border-radius: 8px;
            box-shadow: 0 0 8px rgba(0,0,0,0.1);
            margin-bottom: 15px;
        }

        .nav-tabs .nav-link {
            font-weight: 500;
        }
    </style>
</head>

<body class="p-0">

    <h2 class="mb-4">Purchase Reports</h2>

    <ul class="nav nav-tabs mb-3" id="reportTab">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#listReport">List Report</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#summaryReport">Summary Report</button>
        </li>
    </ul>

    <div class="tab-content">

        <!-- LIST REPORT -->
        <div class="tab-pane fade show active" id="listReport">

            <div class="row mb-3">
                <div class="col-md-3">
                    <label>From Date</label>
                    <input type="date" id="listFromDate" class="form-control">
                </div>
                <div class="col-md-3">
                    <label>To Date</label>
                    <input type="date" id="listToDate" class="form-control">
                </div>
                <div class="col-md-6 d-flex align-items-end justify-content-end gap-2">
                    <button id="btnFilterList" class="btn btn-primary">
                        <i class="bi bi-funnel-fill me-2"></i>Filter
                    </button>
                    <button id="btnPrintList" class="btn btn-secondary">
                        <i class="bi bi-printer me-2"></i>Print List
                    </button>
                </div>
            </div>

            <div id="listReportGraph" class="graph-container"></div>

            <table id="tblListReport" class="table table-bordered table-striped w-100">
                <thead>
                    <tr>
                        <th>Purchase ID</th>
                        <th>Date</th>
                        <th>Supplier</th>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Cost Price</th>
                        <th>Amount</th>
                    </tr>
                </thead>
            </table>
        </div>

        <!-- SUMMARY REPORT -->
        <div class="tab-pane fade" id="summaryReport">

            <div class="row mb-3">
                <div class="col-md-3">
                    <label>From Date</label>
                    <input type="date" id="summaryFromDate" class="form-control">
                </div>
                <div class="col-md-3">
                    <label>To Date</label>
                    <input type="date" id="summaryToDate" class="form-control">
                </div>
                <div class="col-md-6 d-flex align-items-end justify-content-end gap-2">
                    <button id="btnFilterSummary" class="btn btn-primary">
                        <i class="bi bi-funnel-fill me-2"></i>Filter
                    </button>
                    <button id="btnPrintSummary" class="btn btn-secondary">
                        <i class="bi bi-printer me-2"></i>Print Summary
                    </button>
                </div>
            </div>

            <div id="summaryReportGraph" class="graph-container"></div>

            <table id="tblSummaryReport" class="table table-bordered table-striped w-100">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Supplier / Product</th>
                        <th>Total Qty</th>
                        <th>Total Amount</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

    <script>
        let listTable, summaryTable;
        let listChart = null;
        let summaryChart = null;

        $(document).ready(function(){

            listTable = $('#tblListReport').DataTable({
                ajax:{
                    url:'/Purchase/GetPurchaseList',
                    data:d=>{
                        d.fromDate = $('#listFromDate').val();
                        d.toDate = $('#listToDate').val();
                    }
                },
                columns:[
                    {data:'purchaseId'},
                    {data:'purchaseDate'},
                    {data:'supplierName'},
                    {data:'productName'},
                    {data:'qty'},
                    {data:'costPrice'},
                    {data:'amount'}
                ]
            });

            summaryTable = $('#tblSummaryReport').DataTable({
                ajax:{
                    url:'/Purchase/GetPurchaseSummary',
                    data:d=>{
                        d.fromDate = $('#summaryFromDate').val();
                        d.toDate = $('#summaryToDate').val();
                    }
                },
                columns:[
                    {data:'purchaseDate'},
                    {data:'supplierName'},
                    {data:'totalQty'},
                    {data:'totalAmount'}
                ]
            });

            $('#btnFilterList').click(()=>{
                listTable.ajax.reload(()=> showGraph(listTable,'listReportGraph','amount','list'));
            });

            $('#btnFilterSummary').click(()=>{
                summaryTable.ajax.reload(()=> showGraph(summaryTable,'summaryReportGraph','totalAmount','summary'));
            });

            $('#btnPrintList').click(()=>printReport(listTable,"Purchase List Report"));
            $('#btnPrintSummary').click(()=>printReport(summaryTable,"Purchase Summary Report"));
        });

        function showGraph(tableObj, containerId, field, type){

            let data = tableObj.rows({search:'applied'}).data().toArray();
            if(data.length === 0) return;

            let labels = data.map(r => r.purchaseDate);
            let values = data.map(r => r[field]);

            if(type==='list' && listChart){ listChart.destroy(); listChart=null; }
            if(type==='summary' && summaryChart){ summaryChart.destroy(); summaryChart=null; }

            document.getElementById(containerId).innerHTML =
                `<canvas id="${containerId}_canvas" style="width:100%;height:300px;"></canvas>`;

            let ctx = document.getElementById(containerId+"_canvas").getContext('2d');

            let newChart = new Chart(ctx,{
                type:'bar',
                data:{ labels:labels, datasets:[{ data:values, backgroundColor:'#0d6efd'}]},
                options:{ responsive:true, plugins:{legend:{display:false}}, scales:{y:{beginAtZero:true}}}
            });

            if(type==='list') listChart=newChart;
            if(type==='summary') summaryChart=newChart;
        }


        /* ✅ ORIGINAL PRINT FUNCTION RESTORED */
        function printReport(tableObj, title){

            let data = tableObj.rows({search:'applied'}).data().toArray();
            let headers = tableObj.columns().header().toArray().map(x => x.innerText);

            let html = "<table><thead><tr>";
            headers.forEach(h => html += "<th>" + h + "</th>");
            html += "</tr></thead><tbody>";
            data.forEach(r => {
                html += "<tr>";
                Object.values(r).forEach(c => html += "<td>" + c + "</td>");
                html += "</tr>";
            });
            html += "</tbody></table>";

            let w = window.open("", "", "width=1200,height=900");

            w.document.write(`
                <html>
                <head>
                    <title>${title}</title>
                    <style>
                        body { font-family: Arial; margin:20px; }
                        h2 { text-align:center; }
                        table { width:100%; border-collapse:collapse; }
                        th,td { border:1px solid #000; padding:8px; text-align:center; }
                        th { background:#0d6efd; color:#fff; }
                    </style>
                </head>
                <body>
                    <h2>${title}</h2>
                    ${html}
                </body>
                </html>
            `);

            w.document.close();
            w.print();
        }
    </script>

</body>
</html>