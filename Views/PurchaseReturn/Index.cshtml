@{
    ViewData["Title"] = "Purchase Return";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Purchase Return</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- DataTables -->
    <link href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" rel="stylesheet">

    <!-- Select2 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #eef2f7, #d9e4f5);
            font-family: 'Segoe UI', sans-serif;
        }

        .main-card {
            background: #ffffff;
            border-radius: 15px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
            margin-top: 20px;
        }

        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        }

        .card-header {
            border-radius: 15px 15px 0 0 !important;
            font-size: 18px;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .btn {
            border-radius: 10px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .btn-primary {
            background: linear-gradient(45deg, #0d6efd, #3a8dff);
            border: none;
        }

        .btn-success {
            background: linear-gradient(45deg, #198754, #28c76f);
            border: none;
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 18px rgba(0, 0, 0, 0.2);
        }

        .form-control {
            border-radius: 8px;
            box-shadow: none;
            border: 1px solid #ced4da;
            transition: 0.3s;
        }

            .form-control:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 8px rgba(13, 110, 253, 0.25);
            }

        table.dataTable thead {
            background: linear-gradient(45deg, #343a40, #212529);
            color: #fff;
        }

        table.dataTable tbody tr:hover {
            background-color: #f2f6fc;
            transition: 0.2s ease;
        }

        .bi {
            font-size: 20px;
        }

        #btnSubmitBulkReturn {
            padding: 10px 25px;
            font-size: 16px;
        }

        #tblStockLedger {
            border-radius: 12px;
            overflow: hidden;
            background: #ffffff;
        }

            #tblStockLedger thead {
                background: linear-gradient(45deg, #0d6efd, #3a8dff);
                color: #fff;
                font-weight: 600;
                text-transform: uppercase;
                font-size: 13px;
                letter-spacing: 0.5px;
            }

            #tblStockLedger tbody td {
                vertical-align: middle;
                padding: 10px;
                font-size: 14px;
            }

            #tblStockLedger tbody tr {
                transition: all 0.2s ease-in-out;
            }

                #tblStockLedger tbody tr:hover {
                    background-color: #f2f6ff;
                    transform: scale(1.01);
                }

        .badge {
            padding: 6px 10px;
            font-size: 12px;
            border-radius: 20px;
        }

        .dataTables_wrapper .dataTables_filter input {
            border-radius: 25px;
            padding: 6px 15px;
            border: 1px solid #ced4da;
            outline: none;
            transition: 0.3s;
        }

            .dataTables_wrapper .dataTables_filter input:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 8px rgba(13, 110, 253, 0.25);
            }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            border-radius: 8px !important;
            margin: 0 3px;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #0d6efd !important;
                color: #fff !important;
                border: none !important;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
                background: #3a8dff !important;
                color: #fff !important;
            }

        .dataTables_wrapper .dataTables_length select {
            border-radius: 8px;
            padding: 4px 8px;
            border: 1px solid #ced4da;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="card main-card d-flex justify-content-center align-items-center" style="height:10vh;">
            <div class="row w-100 g-3">
                <div class="col-md-6 d-flex">
                    <a href="/Purchase/purchases" class="btn btn-primary btn-lg w-100 d-flex justify-content-center align-items-center">
                        <i class="bi bi-cart-plus me-2"></i> Purchase Entry
                    </a>
                </div>
                <div class="col-md-6 d-flex">
                    <a href="/PurchaseReturn/index" class="btn btn-success btn-lg w-100 d-flex justify-content-center align-items-center">
                        <i class="bi bi-arrow-counterclockwise me-2"></i> Purchase Return
                    </a>
                    
                </div>
            </div>
        </div>
    </div>

    <div class="container mt-3">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Purchase Return</h5>
            </div>
            <div class="card-body">

                <!-- Supplier & PurchaseHeader Dropdowns -->
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold"><i class="bi bi-truck me-2 text-primary"></i> Select Supplier</label>
                        <select id="ReturnSupplierId" class="form-control">
                            <option value="">-- Select Supplier --</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold"><i class="bi bi-card-checklist me-2 text-success"></i> Select Purchase Header</label>
                        <select id="ReturnPurchaseHeaderId" class="form-control">
                            <option value="">-- Select PurchaseHeaderId --</option>
                        </select>
                    </div>
                </div>

                <!-- DataTable -->
                <table id="tblReturnItems" class="table table-bordered table-striped w-100">
                    <thead class="table-dark">
                        <tr>
                            <th>DetailId</th>
                            <th>Product</th>
                            <th>Qty Purchased</th>
                            <th>Barcode</th>
                            <th>Return Qty</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>

                <div class="mt-3">
                <button id="btnSubmitBulkReturn" class="btn btn-success btn-lg mt-3">
                    <i class="bi bi-arrow-left-circle me-1"></i> Purchase Return
                </button>
                    
                </div>
            </div>


            <table id="tblReturnItems1" class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>LedgerId</th>
                        <th>PurchaseId</th>
                        <th>ProductId</th>
                        <th>Qty In</th>
                        <th>Qty Out</th>
                    
                        <th>CmpyId</th>
                        <th>BranchId</th>
                        <th>Date</th>
                        <th>CreatedBy</th>
                    </tr>
                </thead>
            </table>

                      
          </div>
     </div>

    <!-- jQuery & DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
                     $(document).ready(function () {

            $('#tblReturnItems1').DataTable({
                ajax: {
                    url: '/PurchaseReturn/GetStockLedgerData',
                    type: 'GET',
                    dataSrc: 'data'
                },
                columns: [
                    { data: 'LedgerId' },
                    { data: 'PurchaseId' },
                    { data: 'ProductId' },
                    { data: 'QtyIn' },
                    { data: 'QtyOut' },
                    
                    { data: 'CmpyId' },
                    { data: 'BranchId' },
                    { data: 'CreatedOn' },
                    { data: 'CreatedBy' }
                ]
            });

        });
    </script>
    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>

    <script>
        $(document).ready(function () {
            // Load Suppliers
            $.get("/Purchase/GetSuppliers", function (res) {
                $.each(res, function (i, v) {
                    $("#ReturnSupplierId").append(`<option value="${v.supplierId}">${v.supplierName}</option>`);
                });
            });

            $("#ReturnSupplierId").select2({ placeholder: "Search Supplier...", allowClear: true, width: '100%' });
            $("#ReturnPurchaseHeaderId").select2({ placeholder: "Select PurchaseHeaderId...", allowClear: true, width: '100%' });

            // Supplier change → PurchaseHeaders
            $("#ReturnSupplierId").change(function () {
                let supplierId = $(this).val();
                $("#ReturnPurchaseHeaderId").empty().append('<option value="">-- Select PurchaseHeaderId --</option>');
                if (!supplierId) return;

                $.get("/PurchaseReturn/GetPurchaseHeadersBySupplier", { supplierId: supplierId }, function (res) {
                    $.each(res, function (i, v) {
                        $("#ReturnPurchaseHeaderId").append(`<option value="${v.purchaseId}">${v.purchaseId}</option>`);
                    });
                });
            });

            // PurchaseHeader change → Load DataTable
            $("#ReturnPurchaseHeaderId").change(function () {
                let purchaseId = $(this).val();
                if (!purchaseId) return;

                $("#tblReturnItems").DataTable({
                    destroy: true,
                    processing: true,
                    ajax: {
                        url: "/PurchaseReturn/GetPurchaseItemsByHeaderId",
                        type: "GET",
                        data: { purchaseId: purchaseId },
                        dataSrc: "data"
                    },
                    columns: [
                        { data: "detailId" },
                        { data: "productName" },
                        { data: "qty" },
                        { data: "barcode" },
                        {
                            data: null,
                            render: function (data) {
                                return `<input type="number" class="form-control returnQty" min="0" max="${data.qty}">`;
                            }
                        },
                        {
                            data: null,
                            render: function () {
                                return `<input type="text" class="form-control reasonInput" placeholder="Enter reason">`;
                            }
                        }
                    ]
                });
            });

            // Qty validation
            $(document).on("keyup change", ".returnQty", function () {
                let maxQty = parseFloat($(this).attr("max"));
                let enteredQty = parseFloat($(this).val()) || 0;
                if (enteredQty > maxQty) { Swal.fire("Error", "Return qty cannot exceed purchased qty", "error"); $(this).val(""); }
            });

            // Submit Return
            $("#btnSubmitBulkReturn").click(function () {
                let table = $("#tblReturnItems").DataTable();
                let rows = table.rows().data();
                let returnData = [];
                let valid = true;

                rows.each(function (row, i) {
                    let rQty = parseFloat($(".returnQty").eq(i).val()) || 0;
                    let reason = $(".reasonInput").eq(i).val();
                    if (rQty > parseFloat(row.qty)) valid = false;
                    if (rQty > 0) returnData.push({ purchaseId: row.purchaseId, productId: row.productId, returnQty: rQty, reason: reason });
                });

                if (!valid) { Swal.fire("Error", "Return qty cannot exceed purchased qty", "error"); return; }
                if (returnData.length === 0) { Swal.fire("Warning", "Enter return qty to proceed", "warning"); return; }

                $.ajax({
                    url: "/PurchaseReturn/AddBulkPurchaseReturn",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(returnData),
                    success: function (res) {
                        Swal.fire("Success", res.message, "success");
                        $("#ReturnSupplierId").val("").trigger('change');
                        $("#ReturnPurchaseHeaderId").val("").trigger('change');
                        $("#tblReturnItems").DataTable().clear().draw();
                    },
                    error: function () { Swal.fire("Error", "Something went wrong!", "error"); }
                });
            });

        
        // Example usage: when user selects PurchaseHeader from second dropdown
        $("#ReturnPurchaseId").change(function () {
            let purchaseId = $(this).val();
            loadStockLedger(purchaseId);
        });
        });
    </script>
</body>
</html>