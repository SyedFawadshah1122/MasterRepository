@{
    ViewData["Title"] = "Sales Management";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Datatables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">

    <!-- Select2 -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <style>
        body {
            background: #f4f6f9;
        }

        .card {
            border-radius: 14px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            border: none;
        }

        .card-header {
            background: linear-gradient(90deg,#0d6efd,#0a58ca);
            color: white;
            border-radius: 14px 14px 0 0;
        }

        .input-group-text {
            width: 45px;
            justify-content: center;
        }

        .btn-success, .btn-warning, .btn-info {
            border-radius: 10px;
            padding: 10px 25px;
        }

        table.dataTable thead th {
            background-color: #212529 !important;
            color: #fff !important;
        }

        #tblProductList th, #tblProductList td, #tblSales th, #tblSales td {
            text-align: center;
            vertical-align: middle;
        }
    </style>
</head>
<body class="p-0">
    <div class="container mt-3">

        <!-- Header Buttons -->
        <div class="card main-card d-flex justify-content-center align-items-center" style="height:10vh; padding:1rem;">
            <div class="row w-100 g-3">
                <div class="col-md-6 d-flex">
                    <a href="/POS/PosIndex" class="btn btn-primary btn-lg w-100 d-flex justify-content-center align-items-center">
                        <i class="bi bi-cart3 me-2"></i> POS Sale
                    </a>
                </div>
                <div class="col-md-6 d-flex">
                    <a href="/POS/PosIndex" class="btn btn-success btn-lg w-100 d-flex justify-content-center align-items-center">
                        <i class="bi bi-cart3 me-2"></i> POS Return
                    </a>
                </div>
            </div>
        </div>

        <!-- SALE HEADER -->
        <div class="card mt-3">
            <div class="card-header"><h5 class="mb-0"><i class="bi bi-person-fill me-2"></i>Customer Details</h5></div>
            <div class="card-body">
                <input type="hidden" id="SaleId">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Sale Date</label>
                        <div class="input-group">
                            <span class="input-group-text bg-primary text-white"><i class="bi bi-calendar-date-fill"></i></span>
                            <input type="date" id="SaleDate" class="form-control">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Customer</label>
                        <div class="input-group">
                            <select id="CustomerId" class="form-select"><option value="">-- Select Customer --</option></select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Barcode</label>
                        <div class="input-group">
                            <span class="input-group-text bg-danger text-white"><i class="bi bi-upc-scan"></i></span>
                            <input type="text" id="Barcode" class="form-control">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SALE DETAILS -->
        <div class="card mt-4">
            <div class="card-header"><h5 class="mb-0"><i class="bi bi-bag-check-fill me-2"></i>Sale Details</h5></div>
            <div class="card-body">
                <table class="table table-bordered mt-3" id="tblProductList">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Qty</th>
                            <th>Price</th>
                            <th>Amount</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3">Total</th>
                            <th id="totalAmount">0</th>
                            <th></th>
                        </tr>
                    </tfoot>
                </table>

                <div class="text-end mb-3">
                    <button id="btnSubmitSale" class="btn btn-success btn-lg"><i class="bi bi-cart-check-fill me-2"></i>Complete Sale</button>
                    <button class="btn btn-info text-white btn-lg" onclick="openReportPage()"><i class="bi bi-file-earmark-text-fill me-2"></i>Report</button>
                </div>

                <table id="tblSales" class="table table-bordered table-striped mt-4">
                    <thead>
                        <tr>
                            <th>Sale ID</th>
                            <th>Product</th>
                            <th>Qty</th>
                            <th>Price</th>
                            <th>Amount</th>
                            <th>Total</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>

        <!-- JS -->
        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
        <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
        <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

        <script>
            let table; let saleList = [];

            function LoadCustomers(){
                $.get("/POS/GetCustomers", function(res){
                    $("#CustomerId").html('<option></option>');
                    $.each(res,function(i,v){ $("#CustomerId").append(`<option value="${v.CustomerId}">${v.CustomerName}</option>`); });
                    if($('#CustomerId').hasClass("select2-hidden-accessible")) $('#CustomerId').select2('destroy');
                    $('#CustomerId').select2({ width:'100%', placeholder:'Select Customer', allowClear:true });
                });
            }

            function LoadProducts(){
                $.get("/POS/GetProducts", function(res){
                    $("#ProductId").html('<option></option>');
                    $.each(res,function(i,v){ $("#ProductId").append(`<option value="${v.ProductId}" data-price="${v.SellingPrice}">${v.ProductName}</option>`); });
                    if($('#ProductId').hasClass("select2-hidden-accessible")) $('#ProductId').select2('destroy');
                    $('#ProductId').select2({ width:'100%', placeholder:'Select Product', allowClear:true });
                });
            }

            function AddProductToList(p){
                // check if already in list
                let exists = saleList.find(x=>x.productId===p.ProductId);
                if(exists){
                    exists.qty += 1;
                    exists.amount = exists.qty*exists.price;
                } else {
                    saleList.push({ productId:p.ProductId, productName:p.ProductName, qty:1, price:p.SellingPrice, amount:p.SellingPrice });
                }
                renderSaleList();
            }

                        // Barcode enter → fetch product & add to list
            $("#Barcode").on("keyup change", function(e){
                let code = $(this).val();
                if(!code) return;
                $.get("/POS/GetProductByBarcode", { barcode: code }, function(p){
                    if(!p){
                        Swal.fire("Error","Product not found","error");
                        $("#Barcode").val("");
                        return;
                    }
                    AddProductToList(p);
                    $("#Barcode").val("");

                    // ✅ Focus on Qty of the last added product and select value
                    let lastRow = $("#tblProductList tbody tr:last");
                    let qtyInput = lastRow.find(".qtyEdit");
                    if(qtyInput.length){
                        qtyInput.focus();
                        qtyInput.select();
                    }
                });
            });

            function renderSaleList(){
                let tbody=$("#tblProductList tbody"); tbody.empty(); let total=0;
                saleList.forEach((p,i)=>{ total+=p.amount;
                    tbody.append(`<tr>
                        <td>${p.productName}</td>
                        <td><input type="number" class="form-control qtyEdit" data-index="${i}" value="${p.qty}"></td>
                        <td><input type="number" class="form-control priceEdit" data-index="${i}" value="${p.price.toFixed(2)}"></td>
                        <td class="amountCell">${p.amount.toFixed(2)}</td>
                        <td><button class="btn btn-sm btn-danger removeItem" data-index="${i}"><i class="bi bi-trash-fill"></i></button></td>
                    </tr>`);
                });
                $("#totalAmount").text(total.toFixed(2));

                $(".removeItem").off("click").on("click", function(){ let index=$(this).data("index"); saleList.splice(index,1); renderSaleList(); });
                $(".qtyEdit").off("keyup change").on("keyup change", function(){
                    let i=$(this).data("index"); let qty=parseFloat($(this).val())||0;
                    saleList[i].qty=qty; saleList[i].amount=qty*saleList[i].price; renderSaleList();
                });
                $(".priceEdit").off("keyup change").on("keyup change", function(){
                    let i=$(this).data("index"); let price=parseFloat($(this).val())||0;
                    saleList[i].price=price; saleList[i].amount=price*saleList[i].qty; renderSaleList();
                });
            }

            $("#btnSubmitSale").click(function(){
                if(!saleList.length){ Swal.fire("Warning","Add at least one product","warning"); return; }
                let vm={ customerId:$("#CustomerId").val(), saleDate:$("#SaleDate").val(), details:saleList };
                if(!vm.customerId||!vm.saleDate){ Swal.fire("Warning","Fill all required fields","warning"); return; }
                $.ajax({
                    url:"/POS/AddSale", type:"POST", contentType:"application/json", data:JSON.stringify(vm),
                    success:function(){ Swal.fire("Success","Sale completed","success"); saleList=[]; renderSaleList(); ClearForm(); if(table) table.ajax.reload(); },
                    error:function(xhr){ Swal.fire("Error",xhr.responseText||"Sale failed","error"); }
                });
            });

            function ClearForm(){ $("#SaleId,#SaleDate,#Barcode").val(""); $("#CustomerId").val(null).trigger('change'); saleList=[]; renderSaleList(); }

            function openReportPage(){ window.location.href="/POS/SalesReport"; }

            function LoadTable(){
                table=$("#tblSales").DataTable({
                    ajax:{ url:"/POS/GetSales", dataSrc:"" },
                    columns:[
                        {data:"SaleId"}, {data:"productName"}, {data:"qty"}, {data:"price"}, {data:"amount"}, {data:"totalAmount"},
                        {data:"saleId", render:function(id){ return `<div class="d-flex gap-1 w-100"><button class="btn btn-sm btn-info text-white" onclick="PrintSale('${id}')"><i class="bi bi-printer-fill"></i></button></div>`; }}
                    ]
                });
            }

            $(document).ready(function(){ LoadCustomers(); LoadProducts(); LoadTable(); });
        </script>
</body>
</html>