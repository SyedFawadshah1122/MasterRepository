@{
    ViewData["Title"] = "Supplier Master";
    Layout = "_Layout";
}
<style>
.card-header {
            border-radius: 12px 12px 0 0 !important;
            background: linear-gradient(90deg, #0d6efd, #0a58ca);
            color: white;
            padding: 15px 20px;
        }

</style>
<div class="card mt-3">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-person-badge-fill me-2 "></i>Supplier Master</h5>
    </div>

    <div class="card-body">

        <div class="row mb-3">
            <div class="col-md-4">
                <label><i class="bi bi-hash "></i> Supplier ID</label>
                <input type="text" id="SupplierId" class="form-control" placeholder="Enter Supplier ID" />
            </div>
            <div class="col-md-8">
                <label><i class="bi bi-person-lines-fill"></i> Supplier Name</label>
                <input type="text" id="SupplierName" class="form-control" placeholder="Enter Supplier Name" />
            </div>
        </div>

        <div class="mb-3">
            <label><i class="bi bi-telephone-fill"></i> Phone</label>
            <input type="text" id="Phone" class="form-control" placeholder="03xx-xxxxxxx" />
        </div>

        <div class="mb-3">
            <label><i class="bi bi-geo-alt-fill"></i> Address</label>
            <textarea id="Address" class="form-control" rows="2" placeholder="Enter Address"></textarea>
        </div>

        <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" id="Active">
            <label class="form-check-label"><i class="bi bi-check2-circle text-success"></i> Is Active</label>
        </div>

        <button class="btn btn-success me-2" id="btnSaveSupplier"><i class="bi bi-save-fill"></i> Save</button>
        <button class="btn btn-primary me-2" id="btnUpdateSupplier" style="display:none;"><i class="bi bi-arrow-repeat"></i> Update</button>
        <button class="btn btn-secondary" id="btnClearSupplier"><i class="bi bi-eraser-fill"></i> Clear</button>

    </div>
</div>

<hr />

<h4><i class="bi bi-table"></i> Saved Suppliers</h4>

<table id="datatableStyle" class="table table-bordered table-hover table-striped nowrap w-100">
    <thead class="table-dark">
        <tr>
            <th><i class="bi bi-hash"></i> Supplier ID</th>
            <th><i class="bi bi-person-lines-fill"></i> Name</th>
            <th><i class="bi bi-telephone-fill"></i> Phone</th>
            <th><i class="bi bi-geo-alt-fill"></i> Address</th>
            <th class="text-center"><i class="bi bi-check2-circle"></i> Active</th>
            <th class="text-center"><i class="bi bi-tools"></i> Actions</th>
        </tr>
    </thead>
</table>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    $(document).ready(function () {

        var table = $('#datatableStyle').DataTable({
            responsive: true,
            pageLength: 5,
            lengthMenu: [5, 10, 20, 50],
            order: [],
            ajax: {
                url: "/Supplier/GetSuppliers",
                type: "GET",
                dataSrc: ""
            },
            columns: [
                { data: "supplierId" },
                { data: "supplierName" },
                { data: "mobile" },
                { data: "address" },
                {
                    data: "active",
                    className: "text-center",
                    render: d => d ? '<i class="bi bi-check-circle-fill text-success fs-5"></i>' : '<i class="bi bi-x-circle-fill text-danger fs-5"></i>'
                },
                {
                    data: "supplierId",
                    className: "text-center",
                    render: id => `
                        <button class="btn btn-warning btn-sm me-1" onclick="editSupplier('${id}')"><i class="bi bi-pencil-square"></i></button>
                        <button class="btn btn-danger btn-sm" onclick="deleteSupplier('${id}')"><i class="bi bi-trash-fill"></i></button>
                    `
                }
            ]
        });

        $("#btnSaveSupplier").click(function () {
            $.post("/Supplier/SaveSupplier", {
                SupplierId: $("#SupplierId").val(),
                SupplierName: $("#SupplierName").val(),
                Phone: $("#Phone").val(),
                Address: $("#Address").val(),
                Active: $("#Active").is(":checked")
            }, function () {
                Swal.fire({ icon: "success", title: "Supplier Saved", timer: 1500 });
                table.ajax.reload();
                clearForm();
            });
        });

        $("#btnUpdateSupplier").click(function () {
            $.post("/Supplier/UpdateSupplier", {
                SupplierId: $("#SupplierId").val(),
                SupplierName: $("#SupplierName").val(),
                Phone: $("#Phone").val(),
                Address: $("#Address").val(),
                Active: $("#Active").is(":checked")
            }, function () {
                Swal.fire({ icon: "success", title: "Supplier Updated", timer: 1500 });
                table.ajax.reload();
                clearForm();
            });
        });

        $("#btnClearSupplier").click(clearForm);
    });

    function editSupplier(id) {
        $.get("/Supplier/GetSupplierById?id=" + id, function (data) {
            $("#SupplierId").val(data.supplierId).prop("readonly", true);
            $("#SupplierName").val(data.supplierName);
            $("#Phone").val(data.phone);
            $("#Address").val(data.address);
            $("#Active").prop("checked", data.active);

            $("#btnSaveSupplier").hide();
            $("#btnUpdateSupplier").show();
        });
    }

    function deleteSupplier(id) {
        Swal.fire({
            title: "Are you sure?",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d33"
        }).then(res => {
            if (res.isConfirmed) {
                $.post("/Supplier/DeleteSupplier", { id }, function () {
                    Swal.fire({ icon: "success", title: "Supplier Deleted Successfully", timer: 1500 });
                    $('#datatableStyle').DataTable().ajax.reload();
                });
            }
        });
    }

    function clearForm() {
        $("#SupplierId").val("").prop("readonly", false);
        $("#SupplierName").val("");
        $("#Phone").val("");
        $("#Address").val("");
        $("#Active").prop("checked", false);

        $("#btnSaveSupplier").show();
        $("#btnUpdateSupplier").hide();
    }
</script>