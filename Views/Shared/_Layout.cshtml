@{
    ViewData["Title"] = "SoftTech ERP Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SoftTech ERP</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        /* ==================== TOP NAVBAR ==================== */
        .top-navbar {
            width: 100%;
            background: #31333fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.9rem 0.2rem;
            color: #fff;
            position: fixed;
            top: 0;
            z-index: 1200;
        }

        .brand-dropdown {
            cursor: pointer;
            font-weight: 700;
            font-size: 18px;
        }

            .brand-dropdown i {
                margin-left: 5px;
                color: #ffc107;
            }

        .search-bar input {
            width: 200px;
        }

        /* ==================== SIDEBAR ==================== */
        .sidebar {
            position: fixed;
            top: 56px;
            left: 0;
            height: calc(100% - 56px);
            width: 220px;
            background-color: #1b1f3b;
            overflow-x: hidden;
            z-index: 1100;
            padding-top: 10px;
        }

            .sidebar .nav-link {
                display: flex;
                align-items: center;
                color: #fff;
                padding: 12px 15px;
                font-weight: 500;
                cursor: pointer;
            }

                .sidebar .nav-link i {
                    font-size: 1.3rem;
                    margin-right: 10px;
                    transition: color 0.3s;
                }

                .sidebar .nav-link.dashboard i {
                    color: #0dcaf0;
                }

                .sidebar .nav-link.master i {
                    color: #0d6efd;
                }

                .sidebar .nav-link.transaction i {
                    color: #198754;
                }

                .sidebar .nav-link.reports i {
                    color: #fd7e14;
                }

                .sidebar .nav-link:hover i {
                    color: #ffc107;
                }

                .sidebar .nav-link:hover {
                    background: rgba(255,255,255,0.1);
                    border-radius: 8px;
                }

        .content-wrapper {
            margin-left: 220px;
            padding: 80px 20px 20px 20px;
        }

        footer {
            background: #f8f9fa;
            padding: 10px 20px;
            margin-left: 220px;
            clear: both;
            text-align: center;
        }
    </style>
</head>

<body>
    <!-- ==================== TOP NAVBAR ==================== -->
    <nav class="top-navbar">
        <div class="brand-dropdown" id="brandClick">
            <h7>SoftTech ERP</h7>
            <i class="bi bi-caret-down-fill"></i>
        </div>
        <div class="search-bar">
            <input type="search" class="form-control form-control-sm" placeholder="Search...">
        </div>
    </nav>

    <!-- ==================== SIDEBAR ==================== -->
    <div class="sidebar">

        <!-- Dashboard -->
        <div class="nav-item">
            <a class="nav-link dashboard" data-bs-toggle="collapse" href="#dashboardMenu" role="button" aria-expanded="false">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
            <div class="collapse" id="dashboardMenu">
                <a class="nav-link" asp-controller="Home" asp-action="Overview"><i class="bi bi-house me-2" style="color:#ffc107;"></i> Overview</a>
                <a class="nav-link" asp-controller="Home" asp-action="Stats"><i class="bi bi-bar-chart-line me-2" style="color:#0dcaf0;"></i> Stats</a>
            </div>
        </div>

        <!-- Master Dropdown -->
        <div class="nav-item">
            <a class="nav-link master" data-bs-toggle="collapse" href="#masterMenu" role="button" aria-expanded="false">
                <i class="bi bi-gear-fill"></i> Master
            </a>
            <div class="collapse" id="masterMenu">
                <a class="nav-link" asp-controller="Category" asp-action="Categories"><i class="bi bi-diagram-3-fill me-2" style="color:#ffc107;"></i> Category</a>
                <a class="nav-link" asp-controller="Category" asp-action="SubCategories"><i class="bi bi-diagram-3-fill me-3" style="color:#0dcaf0;"></i> Sub Category</a>
                <a class="nav-link" asp-controller="Product" asp-action="Products"><i class="bi bi-box-fill me-2" style="color:#198754;"></i> Products</a>
                <a class="nav-link" asp-controller="Supplier" asp-action="Suppliers"><i class="bi bi-truck me-2" style="color:#fd7e14;"></i> Supplier</a>
                <a class="nav-link" asp-controller="Customer" asp-action="Customers"><i class="bi bi-people-fill me-2" style="color:#6610f2;"></i> Customer</a>
            </div>
        </div>

        <!-- Transaction Dropdown -->
        <div class="nav-item">
            <a class="nav-link transaction" data-bs-toggle="collapse" href="#transactionMenu" role="button" aria-expanded="false">
                <i class="bi bi-arrow-left-right"></i> Transaction
            </a>
            <div class="collapse" id="transactionMenu">
                <a class="nav-link" asp-controller="Purchase" asp-action="Purchases"><i class="bi bi-cart-check-fill me-2"></i> Purchase Invoice</a>
            
                
            </div>
            <div class="collapse" id="transactionMenu">
                <a class="nav-link" asp-controller="POS" asp-action="Posindex"><i class="bi bi-cart3 me-2"></i> POS</a>
            
                
            </div>
            
        </div>

        <!-- Reports Dropdown -->
        <div class="nav-item">
            <a class="nav-link reports" data-bs-toggle="collapse" href="#reportsMenu" role="button" aria-expanded="false">
                <i class="bi bi-bar-chart-fill"></i> Reports
            </a>
            <div class="collapse" id="reportsMenu">
                <span class="nav-link"><i class="bi bi-clock-history me-2"></i> Coming Soon</span>
            </div>
        </div>

    </div>

    <!-- ==================== CONTENT ==================== -->
    <div class="content-wrapper">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- ==================== FOOTER ==================== -->
    <footer class="border-top footer text-muted">
        <div class="container">
            <i class="bi bi-c-circle"></i> 2026 - SoftTech ERP -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ================= BRAND CLICK COLLAPSE ALL MENUS =================
        document.getElementById('brandClick').addEventListener('click', function() {
            ['dashboardMenu','masterMenu','transactionMenu','reportsMenu'].forEach(function(id){
                var el = document.getElementById(id);
                var instance = bootstrap.Collapse.getOrCreateInstance(el);
                instance.hide(); // collapse each menu
            });
        });
    </script>
</body>
</html>