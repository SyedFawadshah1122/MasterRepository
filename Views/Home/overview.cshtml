@{
    ViewData["Title"] = "Overview";
}

<div class="container-fluid">

    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h3><i class="bi bi-house-fill me-2" style="color:#0dcaf0;"></i>Dashboard Overview</h3>
        <span class="text-muted">Welcome back, Admin!</span>
    </div>

    <!-- Row of summary cards -->
    <div class="row g-4">

        <!-- Total Users -->
        <div class="col-md-3">
            <div class="card text-white" style="background: linear-gradient(135deg,#0dcaf0,#0bb8d1);">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-people-fill fs-1 me-3"></i>
                    <div>
                        <h5 class="card-title mb-0">Total Users</h5>
                        <p class="card-text fs-5">1,245</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Products -->
        <div class="col-md-3">
            <div class="card text-white" style="background: linear-gradient(135deg,#198754,#157347);">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-box-seam fs-1 me-3"></i>
                    <div>
                        <h5 class="card-title mb-0">Total Products</h5>
                        <p class="card-text fs-5">856</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Sales -->
        <div class="col-md-3">
            <div class="card text-white" style="background: linear-gradient(135deg,#fd7e14,#e65a00);">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-cart-check-fill fs-1 me-3"></i>
                    <div>
                        <h5 class="card-title mb-0">Total Sales</h5>
                        <p class="card-text fs-5">$12,450</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Active Orders -->
        <div class="col-md-3">
            <div class="card text-white" style="background: linear-gradient(135deg,#6610f2,#5200c7);">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-truck fs-1 me-3"></i>
                    <div>
                        <h5 class="card-title mb-0">Active Orders</h5>
                        <p class="card-text fs-5">142</p>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Charts Section -->
    <div class="row mt-4">

        <!-- Sales Trend -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-graph-up me-2"></i> Sales Trend
                </div>
                <div class="card-body">
                    <canvas id="salesChart" height="200"></canvas>
                </div>
            </div>
        </div>

        <!-- Top Products -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-bar-chart-fill me-2"></i> Top Products
                </div>
                <div class="card-body">
                    <canvas id="productChart" height="200"></canvas>
                </div>
            </div>
        </div>

    </div>

    <!-- Recent Activities -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <i class="bi bi-clock-history me-2"></i> Recent Activities
                </div>
                <div class="card-body">
                    <ul class="list-group">
                        <li class="list-group-item"><i class="bi bi-check-circle text-success me-2"></i> Order #1452 completed.</li>
                        <li class="list-group-item"><i class="bi bi-person-plus text-primary me-2"></i> New user John Doe registered.</li>
                        <li class="list-group-item"><i class="bi bi-box-arrow-in-down text-warning me-2"></i> Product "Laptop X" stock updated.</li>
                        <li class="list-group-item"><i class="bi bi-cart-plus text-info me-2"></i> New purchase invoice #567 created.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Sales Trend Line Chart
    const ctxSales = document.getElementById('salesChart').getContext('2d');
    new Chart(ctxSales, {
        type: 'line',
        data: {
            labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul'],
            datasets: [{
                label: 'Sales ($)',
                data: [1200,1500,1400,1800,1700,1900,2200],
                borderColor: '#fd7e14',
                backgroundColor: 'rgba(253,126,20,0.2)',
                fill: true,
                tension: 0.4
            }]
        },
        options: { responsive:true }
    });

    // Top Products Bar Chart
    const ctxProd = document.getElementById('productChart').getContext('2d');
    new Chart(ctxProd, {
        type: 'bar',
        data: {
            labels: ['Prod A','Prod B','Prod C','Prod D','Prod E'],
            datasets: [{
                label: 'Units Sold',
                data: [50, 75, 60, 90, 45],
                backgroundColor: ['#0dcaf0','#198754','#fd7e14','#6610f2','#0d6efd']
            }]
        },
        options: { responsive:true }
    });
</script>